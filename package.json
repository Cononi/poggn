{
  "name": "pgg-workspace",
  "description": "Development workspace for the pgg CLI, core generator, and dashboard",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:readme": "pnpm --filter @pgg/core build && node --input-type=module -e \"import('./packages/core/dist/readme.js').then(({ writeRootReadme }) => writeRootReadme(process.cwd()))\"",
    "dev:dashboard": "pnpm --filter @pgg/dashboard dev",
    "build:dashboard": "pnpm --filter @pgg/dashboard build",
    "test": "pnpm test:core",
    "test:core": "pnpm --filter @pgg/core test",
    "verify:version-history": "node scripts/verify-version-history-preservation.mjs"
  },
  "bin": {
    "pgg": "./packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "pgg": "link:../../.local/share/pnpm/global/5/node_modules/pgg"
  }
}
