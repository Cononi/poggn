+    "const title = (process.env.COMMIT_TITLE_VALUE ?? \"\").trim();",
+    "const why = (process.env.WHY_SUMMARY_VALUE ?? \"\").trim();",
+    "const footer = (process.env.ISSUE_FOOTER_VALUE ?? \"\").trim();",
+    "process.stdout.write([title, \"\", `Why: ${why}`, \"\", footer, \"\"].join(\"\\n\"));",
+    "NODE",
+    "}",
+    "",
