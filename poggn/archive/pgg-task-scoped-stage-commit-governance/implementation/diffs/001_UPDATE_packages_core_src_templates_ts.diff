+    "esac",
+    "",
+    "SUMMARY=\"$(sanitize_value \"$SUMMARY_RAW\")\"",
+    "WHY_SUMMARY=\"$(sanitize_value \"$WHY_RAW\")\"",
+    "ISSUE_FOOTER=\"$(sanitize_value \"$FOOTER_RAW\")\"",
