+function gitBranchPrefixSh(): string {
+  return lines([
+    "#!/usr/bin/env bash",
+    "set -euo pipefail",
+    "",
+    "load_git_branch_prefixes() {",
+    "  local root_dir=\"$1\"",
+    "  local manifest_path=\"${2:-$root_dir/.pgg/project.json}\"",
+    "",
+    "  WORKING_BRANCH_PREFIX=\"ai\"",
+    "  RELEASE_BRANCH_PREFIX=\"release\"",
+    "",
+    "  [[ -f \"$manifest_path\" ]] || return 0",
+    "",
+    "  local prefixes",
+    "  prefixes=\"$(",
+    "    node -e '",
+    '      const fs = require("fs");',
+    '      const manifest = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));',
+    '      const normalize = (value, fallback) =>',
+    '        String(value ?? fallback)',
+    '          .trim()',
+    '          .replace(/\\/+$/g, "") || fallback;',
+    '      process.stdout.write(',
+    '        `${normalize(manifest.git?.workingBranchPrefix, "ai")}\t${normalize(manifest.git?.releaseBranchPrefix, "release")}`',
+    "      );",
+    `    ' "$manifest_path"`,
+    "  )\"",
+    "",
+    "  WORKING_BRANCH_PREFIX=\"${prefixes%%$'\\t'*}\"",
+    "  RELEASE_BRANCH_PREFIX=\"${prefixes#*$'\\t'}\"",
+    "}"
+  ]);
+}
