+
+function resolveArtifactTopicKey(sourcePath: string | null): string | null {
+  if (!sourcePath) {
+    return null;
+  }
+
+  const match = /^poggn\/(active|archive)\/([^/]+)\//.exec(sourcePath);
+  if (!match) {
+    return null;
+  }
+
+  return `${match[1]}:${match[2]}`;
+}
